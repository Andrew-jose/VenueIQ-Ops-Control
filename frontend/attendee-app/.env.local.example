# ── VenueIQ Attendee App — Environment Variables ──────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.
#
# Production: inject these as Secret Manager–backed env vars in Cloud Run.
# ──────────────────────────────────────────────────────────────────────────

# Firebase (Realtime Database)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_PROJECT_ID=YOUR_GCP_PROJECT_ID
VITE_FIREBASE_DATABASE_URL=https://YOUR_GCP_PROJECT_ID-default-rtdb.firebaseio.com

# Google Maps JavaScript API key (restrict to your domain in GCP console)
VITE_MAPS_API_KEY=YOUR_MAPS_API_KEY

# Gemini API key (for SearchBar AI suggestions)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Firebase Cloud Messaging VAPID public key
# Found in: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FCM_VAPID_KEY=YOUR_FCM_VAPID_PUBLIC_KEY
