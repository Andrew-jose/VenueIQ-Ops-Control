# ── VenueIQ Ops Dashboard — Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.
#
# Production: inject these as Secret Manager–backed env vars in Cloud Run.
# ──────────────────────────────────────────────────────────────────────────

# Firebase (Realtime Database)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_PROJECT_ID=YOUR_GCP_PROJECT_ID
VITE_FIREBASE_DATABASE_URL=https://YOUR_GCP_PROJECT_ID-default-rtdb.firebaseio.com
